rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isValidSize() {
      return request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    function isAdmin() {
      return isAuthenticated() && 
        (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "feraclem@gmail.com");
    }

    match /products/{userId}/{productId}/{fileName} {
      // Anyone can read product images
      allow read: if true;
      
      // Only the owner can upload, and it must be an image under 5MB
      allow create: if isOwner(userId) && isImage() && isValidSize();
      
      // Only the owner or admin can delete images
      allow delete: if isOwner(userId) || isAdmin();
      
      // Allow update for resumable uploads
      allow update: if isOwner(userId) && isImage() && isValidSize();
    }

    match /verifications/{userId}/{fileName} {
      // Only the user or admin can read verification images
      allow read: if isOwner(userId) || isAdmin();
      
      // Only the user can upload their verification images
      allow create: if isOwner(userId) && isImage() && isValidSize();
      
      // Only admin can delete verification images
      allow delete: if isAdmin();
    }
  }
}
